generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("STUDENT") // STUDENT | BUSINESS
  plan         String   @default("FREE") // FREE | MEDIUM | PREMIUM
  avatar       String?
  bio          String?
  skillScore   Int      @default(0)
  xp           Int      @default(0)
  level        Int      @default(1)
  streak       Int      @default(0)
  totalEarned  Int      @default(0)
  lastActiveAt DateTime?
  isPublic     Boolean  @default(true)
  github       String?
  linkedin     String?
  portfolioUrl String?
  createdAt    DateTime @default(now())

  skills       UserSkill[]
  submissions  Submission[]
  tasksPosted  Task[]
  badges       UserBadge[]
}

model Task {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String
  skills        String   // comma-separated
  reward        Int      @default(0)
  xpReward      Int      @default(50)
  difficulty    String   @default("EASY") // EASY | MEDIUM | HARD | EXPERT
  location      String?
  deadline      DateTime?
  status        String   @default("OPEN") // OPEN | IN_PROGRESS | COMPLETED | CLOSED
  maxApplicants Int      @default(10)
  createdAt     DateTime @default(now())

  postedBy      User     @relation(fields: [postedById], references: [id])
  postedById    String
  submissions   Submission[]
}

model Submission {
  id         String   @id @default(cuid())
  content    String
  fileUrl    String?
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED | FLAGGED
  rating     Float?
  feedback   String?
  xpEarned   Int      @default(0)
  certId     String?  // e.g. INTERN-abc123 — issued on approval
  createdAt  DateTime @default(now())
  reviewedAt DateTime?

  task       Task   @relation(fields: [taskId], references: [id])
  taskId     String
  student    User   @relation(fields: [studentId], references: [id])
  studentId  String
}

model UserSkill {
  id        String @id @default(cuid())
  name      String
  level     Int    @default(1)
  tasksUsed Int    @default(0)
  user      User   @relation(fields: [userId], references: [id])
  userId    String
}

model UserBadge {
  id        String   @id @default(cuid())
  badgeType String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}
